# =====================================================================
# Creator OS — Boilerplate open source self-hosted
# =====================================================================
#
# Este arquivo lista TODAS as variáveis de ambiente que o projeto usa.
# Copie para .env e preencha com seus valores reais para desenvolvimento local:
#
#     cp .env.example .env
#
# Para deploy em produção, configure cada variável no painel correto:
#   - Frontend (VITE_*): Vercel → Settings → Environment Variables
#   - Edge Functions:    Supabase Dashboard → Edge Functions → Secrets
#   - Scripts/Actions:   GitHub repo → Settings → Secrets and variables → Actions
#
# Veja README.md para o passo a passo completo.

# =====================================================================
# FRONTEND (Vercel Environment Variables)
# =====================================================================

# URL do seu projeto Supabase.
# Encontre em: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima pública do Supabase (pode ficar exposta — RLS protege).
# Encontre em: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Nome da marca exibido na UI (login, sidebar, dashboard, title do browser).
# Default: 'Creator OS'. Mude aqui se você fez fork e quer rebrandar.
VITE_APP_NAME=Creator OS

# =====================================================================
# EDGE FUNCTIONS SECRETS (Supabase Dashboard)
# =====================================================================
# Configure cada uma em: Supabase Dashboard → Project Settings → Edge Functions → Secrets.
# NÃO coloque essas vars em arquivo .env do frontend — elas vivem só no Supabase.
#
# Observação: SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são auto-injetadas
# pelo runtime das Edge Functions; você não precisa criá-las manualmente.

# Apify (https://apify.com/) — usado para scraping de Reels e perfis Instagram.
# Crie em: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_...

# OpenAI — usado para Whisper (transcrição) e GPT (análise/geração).
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google Gemini — usado para análise visual de vídeo.
# Crie em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# URL pública do frontend deployado na Vercel (ex.: https://seuapp.vercel.app).
# Usada para gerar links de convite enviados por email.
APP_URL=https://your-app.vercel.app

# Resend (https://resend.com/api-keys) — opcional. Se configurado, convites são
# enviados automaticamente por email; sem isso, o owner copia o link manualmente.
RESEND_API_KEY=re_...

# Email remetente dos convites (precisa estar verificado no Resend).
EMAIL_FROM=noreply@seudominio.com

# =====================================================================
# SCRIPTS LOCAIS / GITHUB ACTIONS (opcional)
# =====================================================================
# Necessárias apenas se você usar GitHub Actions para auto-deploy
# de Edge Functions (recomendado — ver README, etapa 4).
# Configure no GitHub: Repo → Settings → Secrets and variables → Actions.

# Personal Access Token do Supabase.
# Crie em: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Project Reference do seu projeto Supabase.
# Encontre em: Supabase Dashboard → Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=abcdefghijklmnop
